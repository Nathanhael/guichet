# --- Test allowlist (ships to origin) ---
# Server unit tests (co-located)
!server/services/*.test.ts
!server/services/ai/*.test.ts
!server/services/auth/*.test.ts
!server/services/ticketLifecycle/*.test.ts
!server/services/messageLifecycle/*.test.ts
!server/socket/*.test.ts
!server/socket/handlers/*.test.ts
!server/middleware/*.test.ts
!server/routes/*.test.ts
!server/trpc/routers/*.test.ts
!server/trpc/routers/platform/*.test.ts
!server/utils/*.test.ts
!server/scripts/*.test.ts

# Server cross-cutting integration tests
!server/__integration__/**/*.test.ts

# Server lifecycle test substrate (PGLite-based; ships with the suite)
!server/test/**/*.ts

# E2E tests (Playwright)
!testing/
!testing/e2e/**/*.spec.ts

# Client behavioral tests (curated)
!client/src/components/ExternalGuestGuard.test.tsx
!client/src/utils/__tests__/notifications.test.ts
!client/src/hooks/useComposeAiImprove.test.ts
!client/src/hooks/useComposeAttachments.test.ts
