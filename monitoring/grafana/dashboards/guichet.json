{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(http_requests_total[5m])",
          "legendFormat": "{{method}} {{route}} {{status}}"
        }
      ]
    },
    {
      "title": "Request Latency P50/P95/P99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total{status=~\"5..\"}[5m])",
          "legendFormat": "{{method}} {{route}}"
        }
      ]
    },
    {
      "title": "Active Socket.io Connections",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "socketio_connections_active",
          "legendFormat": "connections"
        }
      ]
    },
    {
      "title": "Socket.io Events/s",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "rate(socketio_events_total[5m])",
          "legendFormat": "{{event}}"
        }
      ]
    },
    {
      "title": "Ticket Queue Depth",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "ticket_queue_depth",
          "legendFormat": "{{partner_id}}"
        }
      ]
    },
    {
      "title": "AI Pipeline Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(ai_pipeline_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 {{type}}"
        },
        {
          "expr": "histogram_quantile(0.50, rate(ai_pipeline_duration_seconds_bucket[5m]))",
          "legendFormat": "p50 {{type}}"
        }
      ]
    },
    {
      "title": "AI Pipeline Errors/s",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 16 },
      "targets": [
        {
          "expr": "rate(ai_pipeline_errors_total[5m])",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "title": "Audit Chain Verify Failures (total)",
      "description": "Chain-integrity verification failures since process start. `critical` = hash tamper detected. `warn` = transient service-level error (db read timeout, etc). A non-zero critical counter is a compliance incident.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum by (severity) (guichet_audit_chain_verify_failures_total)",
          "legendFormat": "{{severity}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Audit Chain Verify Failure Rate",
      "description": "Rate of verification failures in the last 15m. A sustained non-zero rate means operators are repeatedly hitting a bad chain — investigate archive integrity.",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "rate(guichet_audit_chain_verify_failures_total[15m])",
          "legendFormat": "{{severity}}"
        }
      ]
    },
    {
      "title": "Webhook Delivery Rate",
      "description": "Delivery attempts per second, split by outcome. `error` = transport failure (timeout, DNS, SSRF reject). 5xx = receiver returned server error. Sustained non-2xx means a partner endpoint is unhealthy.",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 30 },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(guichet_webhook_deliveries_total[5m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "title": "Webhook Delivery Latency (p50/p95)",
      "description": "Wall-clock latency of webhook deliveries, including DNS + TLS + receiver processing. A climbing p95 with stable 2xx rate usually means a slow partner; climbing with rising errors means partner is failing open before responding.",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 30 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(guichet_webhook_delivery_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(guichet_webhook_delivery_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "title": "Ticket Lifecycle Events/s",
      "description": "Rate of ticket lifecycle audit rows written by services/ticketAudit.ts, split by action (ticket.created / .reopened / .closed / .assigned / .transferred / .returned_to_queue). Mirrors the audit_log `ticket.*` rows so this graph stays valid even if the audit drawer is empty — the metric is incremented before the DB write.",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 36 },
      "targets": [
        {
          "expr": "sum by (action) (rate(guichet_ticket_audit_events_total[5m]))",
          "legendFormat": "{{action}}"
        }
      ]
    },
    {
      "title": "GDPR Purge Runs (24h)",
      "description": "Counts of GDPR purge runs grouped by outcome. `success` = purge completed end-to-end. `chain_aborted` = audit chain failed verification and purge was halted as a safety measure. `error` = uncaught exception during purge (logs contain stack trace). This panel pairs with the GdprPurgeMissing + GdprPurgeChainAborted alerts — a healthy cluster shows one `success` bar every 24h.",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 36 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "sum by (outcome) (increase(guichet_gdpr_purge_runs_total[24h]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "title": "GDPR Rows Purged (24h)",
      "description": "Rolling 24h count of rows removed or anonymized by the GDPR purge, grouped by scope (ai_usage_log, invites). Zero on a healthy idle tenant is expected — this panel is a retention-audit artifact rather than a liveness check (use GDPR Purge Runs for liveness).",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 36 },
      "targets": [
        {
          "expr": "sum by (scope) (increase(guichet_gdpr_rows_purged_total[24h]))",
          "legendFormat": "{{scope}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["guichet"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Guichet Overview",
  "uid": "guichet-overview"
