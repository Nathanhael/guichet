{
  "mcpServers": {
    "MCP_DOCKER": {
      "command": "docker",
      "args": ["mcp", "gateway", "run"],
      "env": {
        "LOCALAPPDATA": "C:\\Users\\bart_\\AppData\\Local",
        "ProgramData": "C:\\ProgramData",
        "ProgramFiles": "C:\\Program Files"
      },
      "type": "stdio"
    },
    "postgres": {
      "command": "docker",
      "args": [
        "run", "-i", "--rm",
        "--network", "host",
        "mcp/postgres",
        "postgres://user:password@localhost:5432/tessera"
      ],
      "type": "stdio"
    }
  }
}