    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.1.3",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "file-type": "^21.3.3",
    "helmet": "^8.1.0",
    "jose": "^6.2.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
