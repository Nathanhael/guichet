{
  "name": "tessera-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npx tsx watch index.ts",
    "start": "node dist/app.js",
    "build": "Rolldown build",
    "db:migrate": "drizzle-kit migrate",
    "db:baseline": "npx tsx scripts/baseline_drizzle.ts",
    "db:backup": "bash scripts/backup.sh",
    "db:backup:docker": "bash scripts/backup.sh --docker",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "@trpc/server": "^11.13.4",
    "@types/nodemailer": "^7.0.11",
    "argon2": "^0.44.0",
    "cors": "^2.8.5",
    "date-fns-tz": "^3.1.3",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.2.1",
    "file-type": "^21.3.3",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.3",
    "pg": "^8.20.0",
    "pino": "^10.3.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
