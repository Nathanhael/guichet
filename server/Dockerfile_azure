# Stage 1: Build (needs devDependencies for TypeScript compilation)
FROM node:24-alpine AS builder
WORKDIR /app
RUN apk add --no-cache python3 make g++ && npm install -g npm@latest
COPY package.json package-lock.json* ./
RUN npm ci
COPY . .
RUN npm run build

# Stage 2: Production dependencies only
FROM node:24-alpine AS deps
WORKDIR /app
RUN apk add --no-cache python3 make g++ && npm install -g npm@latest
COPY package.json package-lock.json* ./
RUN npm ci --omit=dev \
    # Prune transitive optional peer of drizzle-orm — pglite is a 22 MB
    # in-memory pg shim only used in tests; npm pulls it as an optional
    # peer even with --omit=dev. We can't use --omit=optional because
    # sharp's native binaries are also optional deps.
    && rm -rf node_modules/@electric-sql

# Stage 3: Runtime
FROM node:24-alpine
RUN apk upgrade --no-cache && npm install -g npm@latest
WORKDIR /app
COPY --from=builder /app/dist ./dist
COPY --from=deps /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./
# Migration artifacts — kept in the runtime image so the compiled migrator
# script (dist/db/migrate.js, see server/db/migrate.ts) can apply the
# pending SQL files. Invoke with: node dist/db/migrate.js
# Uses drizzle-orm's migrate() helper; drizzle-kit stays in devDependencies.
COPY --from=builder /app/drizzle ./drizzle
RUN mkdir -p uploads && chown -R node:node /app
USER node
EXPOSE 3001
ENV NODE_ENV=production
CMD ["node", "dist/index.js"]
