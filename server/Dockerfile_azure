# Stage 1: Build (needs devDependencies for TypeScript compilation)
FROM node:24-alpine AS builder
WORKDIR /app
RUN apk add --no-cache python3 make g++ && npm install -g npm@latest
COPY package.json package-lock.json* ./
RUN npm ci
COPY . .
RUN npm run build

# Stage 2: Production dependencies only
FROM node:24-alpine AS deps
WORKDIR /app
RUN apk add --no-cache python3 make g++ && npm install -g npm@latest
COPY package.json package-lock.json* ./
RUN npm ci --omit=dev

# Stage 3: Runtime
FROM node:24-alpine
RUN apk upgrade --no-cache && npm install -g npm@latest
WORKDIR /app
COPY --from=builder /app/dist ./dist
COPY --from=deps /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./
# Migration artifacts — kept in the runtime image so `npm run db:migrate`
# works inside a running container (e.g. `az containerapp exec --command "npm run db:migrate"`).
# drizzle-kit is in `dependencies` (not devDependencies) so it survives `--omit=dev`.
COPY --from=builder /app/drizzle ./drizzle
COPY --from=builder /app/drizzle.config.ts ./
RUN mkdir -p uploads && chown -R node:node /app
USER node
EXPOSE 3001
ENV NODE_ENV=production
CMD ["node", "dist/index.js"]
