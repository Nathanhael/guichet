# DEV ONLY — Do NOT use this Dockerfile for production.
# Production uses server/Dockerfile.prod

# --- Build Stage ---
FROM node:24-alpine AS builder

WORKDIR /app
RUN chown node:node /app && npm install -g npm@latest

USER node

# Copy package manifests and install dependencies
COPY --chown=node:node package*.json ./
RUN npm install --legacy-peer-deps

# --- Production Stage ---
FROM node:24-alpine AS runner

# Patch Alpine OS-level CVEs (e.g. CVE-2025-60876 busybox).
# npm upgrade lives in the builder stage; runtime uses the base-image npm.
RUN apk upgrade --no-cache

WORKDIR /app

# Copy built node_modules and package files. `--chown` so the runtime
# `node` user can rename/write in node_modules without EACCES — required
# for `npm install` / `npm update` inside the container.
COPY --from=builder --chown=node:node /app/node_modules ./node_modules
COPY package*.json ./

# Copy source code with correct permissions
COPY --chown=node:node . .

# Ensure uploads directory exists with correct permissions
RUN mkdir -p uploads && chown node:node uploads

# Switch to non-root user
USER node

EXPOSE 3001

# The 'dev' command is used here as per current setup, 
# but multi-stage is ready for a 'start' command in production.
CMD ["npm", "run", "dev"]
