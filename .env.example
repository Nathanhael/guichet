# =============================================================================
# REQUIRED — the server will not start without these
# =============================================================================

# Must be 64+ chars. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE

# Used by docker-compose.yml to create the database container
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=tessera

# Connection string used by the server
# Use 'db' as host inside Docker, 'localhost' when running server on host machine
DATABASE_URL=postgresql://user:password@db:5432/tessera

# =============================================================================
# LOCAL DEV — you'll likely want these when developing
# =============================================================================

NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173,http://localhost:3001,http://client:5173
COOKIE_SECURE=false
DEMO_MODE=true

# Redis — docker-compose uses 'devpassword'. Host is 'redis' in Docker, 'localhost' on host.
REDIS_URL=redis://:devpassword@redis:6379

# Disable rate limiting for E2E/load testing (never in production)
# DISABLE_RATE_LIMIT=false

# =============================================================================
# AUTH — token lifetimes and cookies
# =============================================================================

# Short-lived access token (refreshed automatically via rotating refresh tokens)
ACCESS_TOKEN_EXPIRY=15m
# Refresh token lifetime (rotated on each use, family-based reuse detection)
REFRESH_TOKEN_EXPIRY=7d
# Set for subdomain cookie sharing (e.g. .tessera.io). Omit for single-domain.
# COOKIE_DOMAIN=.yourdomain.com

# =============================================================================
# OPTIONAL — uncomment and configure as needed
# =============================================================================

# --- Server ---
# LOG_LEVEL=info
# UPLOAD_MAX_SIZE=5242880

# --- Platform Operator Bootstrap (first startup only) ---
# PLATFORM_ADMIN_EMAIL=admin@yourcompany.com
# PLATFORM_ADMIN_PASSWORD=YourStr0ng!Pass

# --- Business Hours (defaults to always-open 00:00–23:59) ---
# BUSINESS_HOURS_START=07:30
# BUSINESS_HOURS_END=22:30

# --- SLA & GDPR ---
# SLA_THRESHOLD_MS=180000
# GDPR_RETENTION_DAYS=30
# PURGE_INTERVAL_MS=86400000

# --- Platform Security ---
# Require TOTP step-up for PlatformView tabs (recommended for production)
# REQUIRE_PLATFORM_STEP_UP=false

# =============================================================================
# FEATURES — enable and configure specific integrations
# =============================================================================

# --- AI Providers ---
# AI_PROVIDER=ollama
# OLLAMA_HOST=http://host.docker.internal:11434
# OLLAMA_MODEL=translategemma:4b
#
# OpenAI-compatible (LM Studio, Groq, xAI, Together AI, DeepSeek, etc.)
# AI_PROVIDER=openai-compatible
# AI_BASE_URL=http://localhost:1234/v1
# AI_API_KEY=sk-dummy
#
# Azure OpenAI
# AI_PROVIDER=azure
# AI_BASE_URL=https://YOUR_RESOURCE.openai.azure.com
# AI_API_KEY=YOUR_KEY
# AZURE_OPENAI_DEPLOYMENT=o4-mini
#
# Google Gemini
# AI_PROVIDER=gemini
# AI_API_KEY=YOUR_GEMINI_KEY
#
# Anthropic (Claude)
# AI_PROVIDER=anthropic
# AI_API_KEY=YOUR_ANTHROPIC_KEY

# --- Azure Entra ID (SSO) ---
# AZURE_AD_TENANT_ID=your-tenant-id
# AZURE_AD_CLIENT_ID=your-client-id
# AZURE_AD_CLIENT_SECRET=your-client-secret
# AZURE_AD_REDIRECT_URI=http://localhost:3001/api/v1/auth/sso/azure/callback

# --- Observability ---
# GRAFANA_ADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION
# PROMETHEUS_USER=
# PROMETHEUS_PASSWORD=
# METRICS_TOKEN=

# --- Web Push (PWA Push Notifications) ---
# Generate keys with: docker compose exec server npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=BNOpYKQKhw5oTHrI7oO8OTlfWmTvyLZilUdyFTTW6juN9ySf3cAKlYBUK5N6vS958UlYQKUdw3fAkpCe9hkGfpM
# VAPID_PRIVATE_KEY=GSLmv3qSmxHUXV5p_w94NdkaopoalLLFROV6p55GKVw
# VAPID_SUBJECT=mailto:admin@tessera.app

# --- E2E Testing (Playwright) ---
# E2E_TEST_DB_URL=postgresql://user:password@localhost:5432/tessera
