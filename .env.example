# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Database
DB_PATH=./database.sqlite

# Authentication (CHANGE IN PRODUCTION)
JWT_SECRET=super-secret-key-replace-in-prod
JWT_EXPIRY=24h

# Ollama (local LLM)
OLLAMA_HOST=http://localhost:11434

# Business hours (Europe/Brussels)
BUSINESS_HOURS_START=07:30
BUSINESS_HOURS_END=22:30

# SLA
SLA_THRESHOLD_MS=180000

# GDPR
GDPR_RETENTION_DAYS=30
PURGE_INTERVAL_MS=86400000

# Logging
LOG_LEVEL=info

# Uploads
UPLOAD_MAX_SIZE=5242880
