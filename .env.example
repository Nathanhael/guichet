# --- Server ---
PORT=3001
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# --- Database (PostgreSQL) ---
# Format: postgresql://[user]:[password]@[host]:[port]/[db]
# For local Docker, the host is usually 'db' when referenced from the server container,
# or 'localhost' when referenced from the host machine.
DATABASE_URL=postgresql://user:password@localhost:5432/tessera
# Individual vars (used by docker-compose.yml)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=tessera

# --- Redis (Scaling & Presence) ---
# Dev compose uses 'devpassword'. Production should use a strong unique password.
REDIS_URL=redis://:devpassword@localhost:6379
# REDIS_PASSWORD=   # Used by docker-compose.prod.yml

# --- Authentication ---
# REQUIRED in production. Must be 64+ chars. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE
# Access token lifetime (short-lived, refreshed automatically via rotating refresh tokens)
ACCESS_TOKEN_EXPIRY=15m
# Refresh token lifetime (rotated on each use, family-based reuse detection)
REFRESH_TOKEN_EXPIRY=7d

# --- Cookies (HttpOnly JWT transport) ---
# COOKIE_SECURE defaults to true. Set to false for local dev without HTTPS.
COOKIE_SECURE=false
# COOKIE_DOMAIN is optional. Set for subdomain sharing (e.g. .tessera.io).
# Omit for single-domain deployments (browser uses request host).
# COOKIE_DOMAIN=.yourdomain.com

# --- Platform Operator Bootstrap ---
# On first startup (no platform operator exists), auto-creates one from these env vars.
# After bootstrap, these are ignored. Remove after first setup if desired.
# PLATFORM_ADMIN_EMAIL=admin@yourcompany.com
# PLATFORM_ADMIN_PASSWORD=   # Min 10 chars, requires upper/lower/digit/special. Omit for SSO-only deployments.

# --- Azure Entra ID (SSO) ---
# Register an app in Azure Portal > App registrations > New registration
# Set redirect URI to: http://localhost:3001/api/v1/auth/sso/azure/callback
# AZURE_AD_TENANT_ID=your-tenant-id
# AZURE_AD_CLIENT_ID=your-client-id
# AZURE_AD_CLIENT_SECRET=your-client-secret
# AZURE_AD_REDIRECT_URI=http://localhost:3001/api/v1/auth/sso/azure/callback

# --- AI & LLM Providers ---
# Options: ollama, azure, openai-compatible
AI_PROVIDER=ollama

# Ollama (Local LLM)
# Use host.docker.internal when running server inside Docker
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=translategemma:4b

# OpenAI-Compatible (LM Studio, LocalAI, vLLM, GPT4All, Oobabooga)
# Also works for: xAI (Grok), Groq, Together AI, Mistral, Perplexity, DeepSeek
# AI_BASE_URL=http://localhost:1234/v1
# AI_API_KEY=sk-dummy

# Azure OpenAI
# AI_BASE_URL=https://YOUR_RESOURCE.openai.azure.com
# AI_API_KEY=YOUR_KEY
# AZURE_OPENAI_DEPLOYMENT=o4-mini

# Google Gemini
# AI_API_KEY=YOUR_GEMINI_KEY

# Anthropic (Claude)
# AI_API_KEY=YOUR_ANTHROPIC_KEY

# --- Business Hours (Defaults) ---
BUSINESS_HOURS_START=07:30
BUSINESS_HOURS_END=22:30

# --- Metrics & Observability ---
# Prometheus default (local) has no auth.
# PROMETHEUS_USER=
# PROMETHEUS_PASSWORD=

# Grafana admin password. Change in production!
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION

# --- SLA & GDPR ---
SLA_THRESHOLD_MS=180000
GDPR_RETENTION_DAYS=30
PURGE_INTERVAL_MS=86400000

# --- Logging ---
# Levels: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# --- Uploads ---
# Max size in bytes (default 5MB)
UPLOAD_MAX_SIZE=5242880

# --- E2E Testing (Playwright) ---
# Used by global-setup.ts to seed test data
E2E_TEST_DB_URL=postgresql://user:password@localhost:5432/tessera
