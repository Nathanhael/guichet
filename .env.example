# =============================================================================
# Guichet — environment reference
# =============================================================================
# Copy to .env, fill in your values. Each key is documented inline.
# Server validates this on boot via server/config.ts; missing required keys
# will FATAL exit. Production-mode safety checks fire when NODE_ENV=production.
# =============================================================================


# =============================================================================
# REQUIRED — server will not boot without these
# =============================================================================

# Signs/verifies JWT access tokens (HttpOnly cookie auth).
# REQUIREMENT: 64+ chars. Rotation logs every user out (sessions become unverifiable).
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE

# Used by docker-compose.yml to provision the Postgres container on first run.
# Changing after init has no effect — wipe the volume to re-init.
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=guichet

# Server connects with this URL. Must match POSTGRES_* above.
# Host: 'db' inside Docker network, 'localhost' when running server on host machine.
DATABASE_URL=postgresql://user:password@db:5432/guichet


# =============================================================================
# LOCAL DEV — defaults wired for local development. Several FATAL in prod.
# =============================================================================

# Triggers production safety checks in config.ts when set to "production".
NODE_ENV=development

# Express listen port. Client + lb expect 3001.
PORT=3001

# Comma-separated list of origins allowed to make browser requests.
# FATAL in prod if it contains "localhost".
CORS_ORIGIN=http://localhost:5173,http://localhost:3001,http://client:5173

# Forces Secure flag on auth cookies (HTTPS-only). Must be true in prod.
# FATAL in prod if false.
COOKIE_SECURE=false

# Exposes the dev-login picker on LoginView (mints JWTs without SSO).
# FATAL in prod — would expose credential-free login on a public endpoint.
DEMO_MODE=true

# Bypasses Express rate limiter (lets E2E + manual tests hammer endpoints).
# FATAL in prod.
DISABLE_RATE_LIMIT=true

# Socket.io adapter (horizontal scaling) + presence + AI summary cache + repetition store.
# Docker compose uses 'devpassword' (redis://:devpassword@redis:6379).
# WARN in prod if no auth in URL.
REDIS_URL=redis://:devpassword@redis:6379


# =============================================================================
# AUTH — token lifetimes
# =============================================================================

# How long an access token (JWT cookie) is valid before client must refresh.
# Short = better security on revocation. Refresh is automatic via useTokenRefresh.
ACCESS_TOKEN_EXPIRY=15m

# How long a refresh token (rotated on every use) lives.
# Determines max idle time before user must re-login. Family reuse = full revoke.
REFRESH_TOKEN_EXPIRY=7d

# Optional. Set if cookies must span subdomains (e.g. .guichet.io).
# Omit for single-host deployments.
# COOKIE_DOMAIN=.yourdomain.com


# =============================================================================
# PLATFORM OPERATOR BOOTSTRAP — first startup only
# =============================================================================

# On first boot with no platform_operator in users table, the bootstrap service
# auto-creates one with this email. Subsequent logins are SSO-only.
# Set to your real email before first prod boot.
# PLATFORM_ADMIN_EMAIL=admin@yourcompany.com


# =============================================================================
# FIELD ENCRYPTION — used by webhook secrets, AI API keys, SMTP creds
# =============================================================================

# AES-GCM key. encryption.ts encrypts JSONB credential blobs in the DB so dumps
# don't leak secrets. CRITICAL: lose this and you cannot decrypt existing rows.
# Do NOT rotate after data exists — re-encrypt migration is required.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# (AI_KEY_ENCRYPTION_SECRET is a legacy alias — both work, FIELD_ENCRYPTION_SECRET wins.)
FIELD_ENCRYPTION_SECRET=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE


# =============================================================================
# AI — global toggle + provider config (per-partner overrides apply)
# =============================================================================

# Global kill-switch for ALL AI features (improvement, summarize, translate, copilot).
# Per-partner aiEnabled flag also applies on top.
AI_ENABLED=true

# Which factory branch to instantiate. Options: azure | openai-compatible
AI_PROVIDER=azure

# Azure OpenAI
# AI_BASE_URL=https://<your-resource>.openai.azure.com/
# AI_API_KEY=<your-key>
# AZURE_OPENAI_DEPLOYMENT=<chat-deployment-name>
# (Whisper deployment is configured per-partner via PlatformView, not env.)

# OpenAI-compatible (LM Studio, Groq, xAI, Together AI, DeepSeek, etc.)
# AI_PROVIDER=openai-compatible
# AI_BASE_URL=http://localhost:1234/v1
# AI_API_KEY=sk-dummy

# Optional. Per-AI-call timeout. Defaults to a sensible value in code.
# AI_TIMEOUT_MS=30000


# =============================================================================
# GDPR — message retention + purge cadence
# =============================================================================

# Messages older than this are purged in the daily job. 30 = EU baseline.
GDPR_RETENTION_DAYS=30

# How often the purge job runs. 86400000 = 24h.
PURGE_INTERVAL_MS=86400000

# Optional. AI usage log retention.
# AI_USAGE_RETENTION_DAYS=90

# Optional. Days before audit_log rows roll into the WORM archive.
# AUDIT_ARCHIVE_DELAY_DAYS=30

# Optional. CSAT free-text comments pseudonymized after this many days.
# RATINGS_COMMENT_RETENTION_DAYS=90


# =============================================================================
# LOGGING & UPLOADS
# =============================================================================

# pino verbosity: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Max upload bytes per file. Default 5MB (5242880).
UPLOAD_MAX_SIZE=5242880

# Optional. CSV of allowed MIME types. Override only if you want to NARROW
# (or extend with PowerPoint). Regex enforces image/*, PDF, Office, CSV, text only.
# Code default already permits: PNG, JPEG, WebP, PDF, plain text, CSV, .doc, .docx, .xls, .xlsx
# UPLOAD_ALLOWED_TYPES=image/png,image/jpeg,image/webp,application/pdf,text/plain,text/csv,application/csv,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
# To also allow PowerPoint, append: ,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation


# =============================================================================
# AZURE ENTRA ID (SSO) — required in prod (only login path)
# =============================================================================
# Setup runbook: docs/SSO_SETUP_RUNBOOK.md
# Missing any of TENANT_ID / CLIENT_ID / CLIENT_SECRET / REDIRECT_URI = 503 on SSO start.

# Tenant Guichet trusts.
# AZURE_AD_TENANT_ID=your-tenant-id

# Guichet's app registration ID in that tenant.
# AZURE_AD_CLIENT_ID=your-client-id

# Proves to Entra it's really Guichet calling. Rotate periodically.
# AZURE_AD_CLIENT_SECRET=your-client-secret

# Where Entra POSTs the auth code back. Must match EXACTLY what's registered
# in the Entra app (path, scheme, host, port). Mismatch = AADSTS50011 error.
# AZURE_AD_REDIRECT_URI=http://localhost:3001/api/v1/auth/sso/azure/callback

# Frontend base URL — SSO callback redirects here after login.
# Default 'http://localhost:3001' is FATAL in prod (localhost check). Override always.
# FRONTEND_URL=http://localhost:5173

# Optional. CSV of email domains treated as internal staff. Internal users can run
# destructive admin actions (webhook CRUD, member invite/remove, etc).
# Anyone outside this list is flagged isExternal=true (B2B guest model) and
# is BLOCKED from destructive admin endpoints (gated by destructiveAdminProcedure).
# Leave empty if you only onboard guests.
# INTERNAL_EMAIL_DOMAINS=yourcompany.com
