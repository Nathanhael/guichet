# =============================================================================
# REQUIRED — the server will not start without these
# =============================================================================

# Must be 64+ chars. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE

# Used by docker-compose.yml to create the database container
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=guichet

# Connection string used by the server
# Use 'db' as host inside Docker, 'localhost' when running server on host machine
DATABASE_URL=postgresql://user:password@db:5432/guichet

# =============================================================================
# LOCAL DEV — you'll likely want these when developing
# =============================================================================

NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173,http://localhost:3001,http://client:5173
COOKIE_SECURE=false
DEMO_MODE=true

# Redis — docker-compose uses 'devpassword'. Host is 'redis' in Docker, 'localhost' on host.
REDIS_URL=redis://:devpassword@redis:6379

# =============================================================================
# AUTH — token lifetimes and cookies
# =============================================================================

# Short-lived access token (refreshed automatically via rotating refresh tokens)
ACCESS_TOKEN_EXPIRY=15m
# Refresh token lifetime (rotated on each use, family-based reuse detection)
REFRESH_TOKEN_EXPIRY=7d
# Set for subdomain cookie sharing (e.g. .guichet.io). Omit for single-domain.
# COOKIE_DOMAIN=.yourdomain.com

# =============================================================================
# OPTIONAL — uncomment and configure as needed
# =============================================================================

# --- Server ---
# LOG_LEVEL — logging verbosity: debug | info | warn | error (default: info)
# LOG_LEVEL=info
# UPLOAD_MAX_SIZE — max file upload size in bytes. Default: 5MB (5242880 bytes)
# UPLOAD_MAX_SIZE=5242880

# --- Platform Operator Bootstrap (first startup only) ---
# SSO-only — no password needed.
# PLATFORM_ADMIN_EMAIL=admin@yourcompany.com

# --- GDPR ---
# GDPR_RETENTION_DAYS — purge messages older than this (30 days = EU compliance)
GDPR_RETENTION_DAYS=30
# PURGE_INTERVAL_MS — how often to run GDPR purge job (86400000ms = 24 hours)
PURGE_INTERVAL_MS=86400000

# =============================================================================
# FEATURES — enable and configure specific integrations
# =============================================================================

# --- Field Encryption (required for webhook secrets, AI API keys) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# FIELD_ENCRYPTION_SECRET is the canonical name; AI_KEY_ENCRYPTION_SECRET is a legacy alias.
# Either one works — encryption.ts prefers FIELD_ENCRYPTION_SECRET if both are set.
FIELD_ENCRYPTION_SECRET=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE
# AI_KEY_ENCRYPTION_SECRET=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE

# --- AI Providers ---
# AI_PROVIDER=ollama
# OLLAMA_HOST=http://host.docker.internal:11434
# OLLAMA_MODEL=translategemma:4b
#
# OpenAI-compatible (LM Studio, Groq, xAI, Together AI, DeepSeek, etc.)
# AI_PROVIDER=openai-compatible
# AI_BASE_URL=http://localhost:1234/v1
# AI_API_KEY=sk-dummy
#
# Azure OpenAI
# AI_PROVIDER=azure
# AI_BASE_URL=https://YOUR_RESOURCE.openai.azure.com
# AI_API_KEY=YOUR_KEY
# AZURE_OPENAI_DEPLOYMENT=gpt-5-mini

# --- Azure Entra ID (SSO) ---
# AZURE_AD_TENANT_ID=your-tenant-id
# AZURE_AD_CLIENT_ID=your-client-id
# AZURE_AD_CLIENT_SECRET=your-client-secret
# AZURE_AD_REDIRECT_URI=http://localhost:3001/api/v1/auth/sso/azure/callback

# --- Observability ---
# GRAFANA_ADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION
# PROMETHEUS_USER=
# PROMETHEUS_PASSWORD=
# METRICS_TOKEN — shared secret between /metrics and Prometheus scraper.
# Generate with: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# Dev: docker-compose.yml has a hardcoded default that matches monitoring/prometheus.yml.
# Prod: set this AND update your Prometheus config's `authorization.credentials`.
# METRICS_TOKEN=

# --- Alertmanager (generic webhook delivery) ---
# Alertmanager POSTs fired alerts as JSON to this URL. Until set, alerts
# fire but delivery fails silently. Examples:
#   https://ntfy.sh/your-secret-topic          (free, no signup)
#   https://your.pipedream.net/...             (for fan-out to multiple channels)
#   https://ops.yourdomain.com/alerts          (your own endpoint)
# ALERTMANAGER_WEBHOOK_URL=
#
# Optional per-receiver overrides (default/audit/oncall/integrations):
# ALERTMANAGER_DEFAULT_WEBHOOK_URL=
# ALERTMANAGER_AUDIT_WEBHOOK_URL=
# ALERTMANAGER_ONCALL_WEBHOOK_URL=
# ALERTMANAGER_INTEGRATIONS_WEBHOOK_URL=

