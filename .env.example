# --- Server ---
PORT=3001
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# --- Database (PostgreSQL) ---
# Format: postgresql://[user]:[password]@[host]:[port]/[db]
# For local Docker, the host is usually 'db' when referenced from the server container,
# or 'localhost' when referenced from the host machine.
DATABASE_URL=postgresql://user:password@localhost:5432/tessera
# Individual vars (used by docker-compose.yml)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=tessera

# --- Redis (Scaling & Presence) ---
# Default for local development has no password.
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=

# --- Authentication ---
# REQUIRED in production. Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=super-secret-key-replace-in-prod
JWT_EXPIRY=24h

# --- AI & LLM Providers ---
# Options: ollama, azure, openai-compatible
AI_PROVIDER=ollama

# Ollama (Local LLM)
# Use host.docker.internal when running server inside Docker
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=translategemma:4b

# OpenAI-Compatible (LM Studio, LocalAI, vLLM, GPT4All, Oobabooga)
# Also works for: xAI (Grok), Groq, Together AI, Mistral, Perplexity, DeepSeek
# AI_BASE_URL=http://localhost:1234/v1
# AI_API_KEY=sk-dummy

# Azure OpenAI
# AI_BASE_URL=https://YOUR_RESOURCE.openai.azure.com
# AI_API_KEY=YOUR_KEY
# AZURE_OPENAI_DEPLOYMENT=o4-mini

# Google Gemini
# AI_API_KEY=YOUR_GEMINI_KEY

# Anthropic (Claude)
# AI_API_KEY=YOUR_ANTHROPIC_KEY

# --- Business Hours (Defaults) ---
BUSINESS_HOURS_START=07:30
BUSINESS_HOURS_END=22:30

# --- Metrics & Observability ---
# Prometheus default (local) has no auth.
# PROMETHEUS_USER=
# PROMETHEUS_PASSWORD=

# Grafana default login: admin / admin
GRAFANA_ADMIN_PASSWORD=admin

# --- SLA & GDPR ---
SLA_THRESHOLD_MS=180000
GDPR_RETENTION_DAYS=30
PURGE_INTERVAL_MS=86400000

# --- Logging ---
# Levels: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# --- Uploads ---
# Max size in bytes (default 5MB)
UPLOAD_MAX_SIZE=5242880

# --- E2E Testing (Playwright) ---
# Used by global-setup.ts to seed test data
E2E_TEST_DB_URL=postgresql://user:password@localhost:5432/tessera
